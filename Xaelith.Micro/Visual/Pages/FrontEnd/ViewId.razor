@page "/view/id/{id}"
@inherits XaelithFrontEndPage

<NavBar />

<main>
    @if (Post == null || (!Post.Metadata.Published && !UserContext.IsAuthenticated))
    {
        <NotFound Message="@NotFoundMessage"/>
    }
    else
    {
        <PostView Post="@Post"/>
    }
</main>

<Footer />

@code {
    [CascadingParameter]
    public UserContext UserContext { get; set; } = null!;

    [Parameter]
    public required string Id { get; set; }
    
    protected override string Title
        => Post != null
            ? Post.Metadata.Title
            : "post not found";
    
    private Post? Post { get; set; }

    private string NotFoundMessage
        => $"No post with ID <code>{Id}</code> exists _";
    
    protected override void OnParametersSet()
    {
        Post = Content.GetPostById(Id);
    }
    
    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender)
        {
            if (!UserContext.IsAuthenticated)
            {
                if (Post != null)
                    Statistics.PostHit(Post.Id);
            }
        }
    }
}