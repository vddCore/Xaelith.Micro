@layout AdminShell

@page "/admin/manage/categories"
@using Category = Xaelith.Micro.Infrastructure.DataModel.Core.Content.Category
@inherits XaelithRestrictedPage

@inject IModalService Modals;
@inject IToastService Toasts;

<h1 class="admin-view-title">@Title</h1>

<div class="admin-inner-content">
    <EditForm Model="CategoryEditContext" OnSubmit="@SaveCategories">
        <CategoryEditor CategoryEditContext="CategoryEditContext"
                        OnAddRequested="@AddEmptyCategory"
                        OnDeleteRequested="@DeleteCategory"
                        OnDiscardRequested="@DiscardChanges"/>
    </EditForm>
</div>

@code {
    [CascadingParameter]
    public UserContext UserContext { get; set; } = null!;

    protected override string Title => "categories";

    private CategoryEditContext CategoryEditContext { get; set; } = new();
    private CategoryEditContext PreviousState { get; set; } = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();

        foreach (var (name, category) in Configuration.Root!.Content.Categories)
        {
            CategoryEditContext.Entries.Add(new(
                name, 
                category.Description,
                category.ShowOnMainPage
            ));
        }

        CategoryEditContext.Entries = CategoryEditContext.Entries
            .OrderBy(x => x.Name)
            .ToList();

        PreviousState = CategoryEditContext.Copy();
    }

    private void SaveCategories(EditContext editContext)
    {
        var context = (CategoryEditContext)editContext.Model;

        try
        {
            if (context.Entries.Any(x => string.IsNullOrWhiteSpace(x.Name)))
            {
                Toasts.Show(
                    "Empty category names are not allowed",
                    ToastSeverity.Warning,
                    3500
                );

                return;
            }

            var uniqueEntries = context.Entries.Select(x => x.Name).Distinct();

            if (uniqueEntries.Count() != context.Entries.Count)
            {
                Toasts.Show(
                    "Category names must be unique",
                    ToastSeverity.Error,
                    3500
                );

                return;
            }

            Configuration.Root!.Content.Categories.Clear();
            foreach (var category in context.Entries)
            {
                if (string.IsNullOrWhiteSpace(category.Name))
                    continue;

                Configuration.Root!.Content.Categories[category.Name] = new Category
                {
                    Description = category.Description,
                    ShowOnMainPage = category.ShowOnMainPage
                };
            }

            context.Entries = context.Entries
                .OrderBy(x => x.Name)
                .ToList();

            Configuration.Save();
            PreviousState = CategoryEditContext.Copy();

            Toasts.Show(
                "Categories updated",
                ToastSeverity.Success
            );
        }
        catch (Exception e)
        {
            Toasts.Show(
                $"Failed to update categories: {e.Message}",
                ToastSeverity.Error,
                3500
            );
        }
    }

    private void AddEmptyCategory()
        => CategoryEditContext.Entries.Insert(0, new(string.Empty, string.Empty, true));

    private void DeleteCategory(int index)
        => CategoryEditContext.Entries.RemoveAt(index);

    private async Task DiscardChanges()
    {
        await Modals.ShowAsync(
            new DialogModalData(
                "Discard changes?",
                "Confirm discarding any changes made to categories.<br/>" +
                "This action is irreversible.",
                "Proceed",
                "Abort",
                DialogModalSeverity.Warning,
                (result) =>
                {
                    if (result)
                        CategoryEditContext = PreviousState.Copy();
                }
            )
        );
    }
}